#!/usr/bin/env bash
set -euo pipefail

HOST="${OPENCLAW101_HOST:-}"
USER="${OPENCLAW101_USER:-root}"
BACKUP_RETENTION_DAYS="${OPENCLAW101_BACKUP_RETENTION_DAYS:-15}"
IDENTITY_FILE="${OPENCLAW101_IDENTITY:-}"
DEFAULT_IDENTITY="${OPENCLAW101_DEFAULT_IDENTITY:-$HOME/.ssh/oc101_ed25519}"
if [[ -z "${IDENTITY_FILE}" && -f "${DEFAULT_IDENTITY}" ]]; then
  IDENTITY_FILE="${DEFAULT_IDENTITY}"
fi
SSH_OPTS=(
  -o StrictHostKeyChecking=no
  -o UserKnownHostsFile=/dev/null
  -o ConnectTimeout=8
)

ssh_cmd() {
  local -a opts=("${SSH_OPTS[@]}")
  if [[ -n "${IDENTITY_FILE}" ]]; then
    opts+=(-i "${IDENTITY_FILE}" -o IdentitiesOnly=yes)
  fi
  if [[ -n "${OPENCLAW101_PASS:-}" ]]; then
    command -v sshpass >/dev/null 2>&1 || { echo "sshpass not found (needed for OPENCLAW101_PASS mode)" >&2; exit 2; }
    sshpass -p "${OPENCLAW101_PASS}" ssh "${opts[@]}" "${USER}@${HOST}" "$@"
  else
    ssh "${opts[@]}" "${USER}@${HOST}" "$@"
  fi
}

scp_cmd() {
  local -a opts=("${SSH_OPTS[@]}")
  if [[ -n "${IDENTITY_FILE}" ]]; then
    opts+=(-i "${IDENTITY_FILE}" -o IdentitiesOnly=yes)
  fi
  if [[ -n "${OPENCLAW101_PASS:-}" ]]; then
    command -v sshpass >/dev/null 2>&1 || { echo "sshpass not found (needed for OPENCLAW101_PASS mode)" >&2; exit 2; }
    sshpass -p "${OPENCLAW101_PASS}" scp "${opts[@]}" "$@"
  else
    scp "${opts[@]}" "$@"
  fi
}

die() {
  echo "$*" >&2
  exit 2
}

validate_retention_days() {
  [[ "$BACKUP_RETENTION_DAYS" =~ ^[0-9]+$ ]] || die "OPENCLAW101_BACKUP_RETENTION_DAYS must be a non-negative integer"
}

timestamp() {
  date -u +"%Y%m%d-%H%M%S"
}

[[ -n "${HOST}" ]] || die "OPENCLAW101_HOST is required (no default host in this repository)"

upgrade_review_stamp_path() {
  echo "$HOME/.codex/tmp/oc101-upgrade-review-${HOST}.stamp"
}

upgrade_review_extract_release() {
  python3 - <<'PY'
import json
import re
import sys
import urllib.request

url = "https://api.github.com/repos/openclaw/openclaw/releases?per_page=30"
req = urllib.request.Request(url, headers={"Accept": "application/vnd.github+json", "User-Agent": "oc101-upgrade-review"})
with urllib.request.urlopen(req, timeout=20) as resp:
    data = json.loads(resp.read().decode("utf-8", errors="replace"))

release = None
for r in data:
    if not r.get("draft") and not r.get("prerelease"):
        release = r
        break

if not release:
    sys.exit("no stable release found")

body = release.get("body") or ""
kw = re.compile(r"(breaking|deprecat|migration|config|default|security|upgrade|changed?|removed?|added?|new)", re.I)
highlights = []
for line in body.splitlines():
    s = line.strip()
    if not s:
        continue
    if kw.search(s):
        s = re.sub(r"^[\-\*\d\.\)\s]+", "", s).strip()
        if s and s not in highlights:
            highlights.append(s)
    if len(highlights) >= 24:
        break

print(f"TAG={release.get('tag_name','')}")
print(f"NAME={release.get('name','')}")
print(f"PUBLISHED_AT={release.get('published_at','')}")
print(f"URL={release.get('html_url','')}")
for h in highlights:
    print(f"HIGHLIGHT={h}")
PY
}

upgrade_review() {
  command -v python3 >/dev/null 2>&1 || die "python3 not found (required for upgrade-review)"

  local release_info tag name published_at url
  local -a highlights
  release_info="$(upgrade_review_extract_release)" || die "failed to fetch/parse GitHub releases"

  tag="$(printf '%s\n' "$release_info" | awk -F= '/^TAG=/{print substr($0,5); exit}')"
  name="$(printf '%s\n' "$release_info" | awk -F= '/^NAME=/{print substr($0,6); exit}')"
  published_at="$(printf '%s\n' "$release_info" | awk -F= '/^PUBLISHED_AT=/{print substr($0,14); exit}')"
  url="$(printf '%s\n' "$release_info" | awk -F= '/^URL=/{print substr($0,5); exit}')"
  while IFS= read -r line; do
    highlights+=("${line#HIGHLIGHT=}")
  done < <(printf '%s\n' "$release_info" | awk '/^HIGHLIGHT=/')

  local status_out
  status_out="$(ssh_cmd 'openclaw update status' 2>&1 || true)"

  local -a keys=(
    "agents.defaults.model.primary"
    "gateway.bind"
    "gateway.trustedProxies"
    "tools.profile"
    "tools.exec.host"
    "tools.exec.security"
    "tools.exec.ask"
    "channels.telegram.streaming"
    "channels.telegram.dmPolicy"
    "channels.telegram.allowFrom"
    "acp.dispatch.enabled"
  )

  echo "=== oc101 upgrade review ==="
  echo "target host: ${USER}@${HOST}"
  echo "review time (UTC): $(date -u +'%Y-%m-%dT%H:%M:%SZ')"
  echo
  echo "latest stable release (GitHub):"
  echo "  tag: ${tag}"
  echo "  name: ${name}"
  echo "  published_at: ${published_at}"
  echo "  url: ${url}"
  echo
  echo "openclaw update status (server):"
  printf '%s\n' "$status_out"
  echo
  echo "release highlights (filtered: breaking/config/migration/security/default/change):"
  if [[ ${#highlights[@]} -eq 0 ]]; then
    echo "  (no keyword-matched highlights extracted; review full notes manually)"
  else
    local h
    for h in "${highlights[@]}"; do
      echo "  - $h"
    done
  fi
  echo
  echo "current server config snapshot (for comparison):"
  local k v
  for k in "${keys[@]}"; do
    v="$(ssh_cmd "openclaw config get $k" 2>&1 || true)"
    printf '  - %s = %s\n' "$k" "$v"
  done
  echo
  echo "next step:"
  echo "  1) confirm release-note impacts with the above config snapshot"
  echo "  2) run backup: oc101 config-backup"
  echo "  3) if confirmed, execute:"
  echo "     OPENCLAW101_UPGRADE_CONFIRM=YES oc101 upgrade --apply [--channel ...] [--tag ...] [--no-restart]"

  mkdir -p "$HOME/.codex/tmp"
  {
    echo "ts=$(date -u +'%Y-%m-%dT%H:%M:%SZ')"
    echo "tag=${tag}"
    echo "host=${HOST}"
  } > "$(upgrade_review_stamp_path)"
  echo "review stamp saved: $(upgrade_review_stamp_path)"
}

run_config_backup() {
  local include_secrets="$1"
  local out_dir="$2"

  mkdir -p "$out_dir"
  local ts local_name local_path remote_tmp
  ts="$(timestamp)"
  local_name="openclaw-101-config-${HOST}-${ts}.tgz"
  local_path="${out_dir%/}/$local_name"

  remote_tmp="/tmp/${local_name}"
  local -a remote_include=(
    "/root/.openclaw/openclaw.json"
    "/root/.openclaw/agents"
  )
  if [[ "$include_secrets" == "1" ]]; then
    remote_include+=("/root/.openclaw/secrets.json")
  fi

  ssh_cmd "sudo tar -czf $(printf %q "$remote_tmp") ${remote_include[*]} 2>/dev/null || tar -czf $(printf %q "$remote_tmp") ${remote_include[*]}"
  scp_cmd "${USER}@${HOST}:$remote_tmp" "$local_path"
  ssh_cmd "rm -f $(printf %q "$remote_tmp")" || true
  printf '%s\n' "$local_path"
}

cleanup_old_backups() {
  local out_dir="$1"
  local removed=0
  local f

  while IFS= read -r f; do
    [[ -n "$f" ]] || continue
    rm -f "$f"
    removed=$((removed + 1))
  done < <(find "$out_dir" -maxdepth 1 -type f -name "openclaw-101-config-${HOST}-*.tgz" -mtime "+${BACKUP_RETENTION_DAYS}" -print 2>/dev/null || true)

  echo "cleanup: removed ${removed} backup(s) older than ${BACKUP_RETENTION_DAYS} days from ${out_dir}"
}

usage() {
  cat >&2 <<'USAGE'
usage: oc101 <command> [args]

Status & health:
  oc101 status
  oc101 gateway-status
  oc101 doctor [--fix]
  oc101 channels-probe

Session maintenance:
  oc101 sessions-cleanup [--dry-run] [--enforce] [--fix-missing] [--agent <id>] [--active-key <key>] [--json]
  oc101 sessions-cleanup --all-agents [--dry-run|--enforce] [--fix-missing] [--json]

Gateway management:
  oc101 gateway-install
  oc101 gateway-start
  oc101 gateway-stop
  oc101 gateway-restart

Config management:
  oc101 config-get <path>
  oc101 config-set <path> <value>
  oc101 config-backup [--include-secrets] [--out <dir>]
  oc101 config-restore <backup.tgz>
  oc101 configure

Update:
  oc101 upgrade-status
  oc101 upgrade-review
  oc101 upgrade-plan
  oc101 upgrade [--channel <stable|beta|dev>] [--tag <dist-tag|version>] [--no-restart] [--apply]

Security:
  oc101 security-audit
  oc101 security-audit-fix
  oc101 secrets-reload

Channels:
  oc101 channels-add
  oc101 channels-login
  oc101 channels-list

Models:
  oc101 models-set <model>
  oc101 models-probe

env overrides:
  OPENCLAW101_HOST (required; no default)
  OPENCLAW101_USER (default root)
  OPENCLAW101_PASS (optional; uses sshpass)
  OPENCLAW101_IDENTITY (optional; explicit ssh -i <path>, highest priority)
  OPENCLAW101_DEFAULT_IDENTITY (fallback key path when OPENCLAW101_IDENTITY is unset; default ~/.ssh/oc101_ed25519)
  OPENCLAW101_BACKUP_RETENTION_DAYS (default 15; auto-clean local backups older than this)
  OPENCLAW101_UPGRADE_CONFIRM=YES (required when running oc101 upgrade --apply)
USAGE
}

sub="${1:-}"
shift || true
validate_retention_days

case "$sub" in
  status)
    ssh_cmd 'openclaw status'
    ;;
  gateway-status)
    ssh_cmd 'openclaw gateway status'
    ;;
  doctor)
    if [[ $# -gt 0 ]]; then
      ssh_cmd "openclaw doctor $*"
    else
      ssh_cmd 'openclaw doctor'
    fi
    ;;
  channels-probe)
    ssh_cmd 'openclaw channels status --probe'
    ;;
  sessions-cleanup)
    # Default to all agents + dry-run when no explicit action is provided.
    if [[ $# -eq 0 ]]; then
      ssh_cmd 'openclaw sessions cleanup --all-agents --dry-run --json'
      exit 0
    fi
    ssh_cmd "openclaw sessions cleanup $*"
    ;;

  gateway-install)
    ssh_cmd 'openclaw gateway install'
    ;;
  gateway-start)
    ssh_cmd 'openclaw gateway start'
    ;;
  gateway-stop)
    ssh_cmd 'openclaw gateway stop'
    ;;
  gateway-restart)
    ssh_cmd 'openclaw gateway restart'
    ;;

  config-get)
    [[ $# -eq 1 ]] || { usage; exit 2; }
    ssh_cmd "openclaw config get $1"
    ;;
  config-set)
    [[ $# -ge 2 ]] || { usage; exit 2; }
    key="$1"; shift
    # Value may contain spaces; pass as a single shell-escaped string.
    val="$*"
    ssh_cmd "openclaw config set $key $(printf %q "$val")"
    ;;
  config-backup)
    include_secrets="0"
    out_dir="$HOME/.codex/backups/oc101-ops"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --include-secrets)
          include_secrets="1"
          shift
          ;;
        --out)
          [[ $# -ge 2 ]] || die "missing value for --out"
          out_dir="$2"
          shift 2
          ;;
        -h|--help)
          usage
          exit 0
          ;;
        *)
          die "unknown arg for config-backup: $1"
          ;;
      esac
    done

    local_path="$(run_config_backup "$include_secrets" "$out_dir")"
    echo "saved: $local_path"
    cleanup_old_backups "$out_dir"
    ;;
  config-restore)
    [[ $# -eq 1 ]] || { usage; exit 2; }
    backup_path="$1"
    [[ -f "$backup_path" ]] || die "file not found: $backup_path"
    remote_tmp="/tmp/oc101-restore-$(timestamp).tgz"
    scp_cmd "$backup_path" "${USER}@${HOST}:$remote_tmp"
    ssh_cmd "tar -xzf $(printf %q "$remote_tmp") -C / && rm -f $(printf %q "$remote_tmp")"
    echo "restored from: $backup_path"
    ;;
  configure)
    ssh_cmd 'openclaw configure'
    ;;

  upgrade-status)
    ssh_cmd 'openclaw update status'
    ;;
  upgrade-review)
    upgrade_review
    ;;
  upgrade-plan)
    cat <<'TXT'
Upgrade workflow (safe-ish):

  1) Automated review (GitHub release + server config snapshot)
     oc101 upgrade-review

  2) Preflight on the server
     oc101 upgrade-status
     oc101 doctor

  3) Backup state/config locally (recommended)
     oc101 config-backup
     # include secrets only if you will store the backup securely:
     oc101 config-backup --include-secrets

  4) Dry-run the updater (optional)
     openclaw update --dry-run

  5) Apply update (after confirming changes)
     OPENCLAW101_UPGRADE_CONFIRM=YES oc101 upgrade --apply

  6) Verify
     oc101 status
     oc101 gateway-status
TXT
    ;;
  upgrade)
    apply="0"
    update_args=()
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --apply)
          apply="1"
          shift
          ;;
        --channel|--tag|--timeout)
          [[ $# -ge 2 ]] || die "missing value for $1"
          update_args+=("$1" "$2")
          shift 2
          ;;
        --no-restart|--json|--dry-run)
          update_args+=("$1")
          shift
          ;;
        -h|--help)
          usage
          exit 0
          ;;
        *)
          die "unknown arg for upgrade: $1"
          ;;
      esac
    done

    if [[ "$apply" != "1" ]]; then
      echo "Refusing to update without --apply." >&2
      echo "Tip: run 'oc101 upgrade-plan' for the recommended workflow." >&2
      echo "To update: oc101 upgrade --apply [--channel ...] [--tag ...] [--no-restart]" >&2
      exit 2
    fi

    stamp="$(upgrade_review_stamp_path)"
    if [[ ! -f "$stamp" ]]; then
      echo "Refusing to update: no upgrade review stamp found." >&2
      echo "Run: oc101 upgrade-review" >&2
      exit 2
    fi
    if [[ "${OPENCLAW101_UPGRADE_CONFIRM:-}" != "YES" ]]; then
      echo "Refusing to update: missing explicit confirmation." >&2
      echo "After reviewing changes, run:" >&2
      echo "  OPENCLAW101_UPGRADE_CONFIRM=YES oc101 upgrade --apply [--channel ...] [--tag ...] [--no-restart]" >&2
      exit 2
    fi

    echo "Creating pre-upgrade backup (without secrets)..."
    backup_out_dir="$HOME/.codex/backups/oc101-ops"
    backup_path="$(run_config_backup "0" "$backup_out_dir")"
    echo "Pre-upgrade backup saved: $backup_path"
    cleanup_old_backups "$backup_out_dir"

    ssh_cmd "openclaw update ${update_args[*]}"
    ;;

  security-audit)
    ssh_cmd 'openclaw security audit'
    ;;
  security-audit-fix)
    ssh_cmd 'openclaw security audit --fix'
    ;;
  secrets-reload)
    ssh_cmd 'openclaw secrets reload'
    ;;

  channels-add)
    ssh_cmd 'openclaw channels add'
    ;;
  channels-login)
    ssh_cmd 'openclaw channels login'
    ;;
  channels-list)
    ssh_cmd 'openclaw channels list'
    ;;

  models-set)
    [[ $# -eq 1 ]] || { usage; exit 2; }
    ssh_cmd "openclaw models set $1"
    ;;
  models-probe)
    ssh_cmd 'openclaw models status --probe'
    ;;

  -h|--help|help|"")
    usage
    ;;
  *)
    echo "unknown command: $sub" >&2
    usage
    exit 2
    ;;
esac
