# Watchdog listener
OC101_WD_BIND_HOST=0.0.0.0
OC101_WD_BIND_PORT=18891
OC101_WD_PATH=/heartbeat

# Shared secret used by heartbeat sender HMAC
OC101_WD_SHARED_SECRET=change-this-secret

# Timeouts
OC101_WD_STALE_AFTER_SECONDS=1200
OC101_WD_CHECK_INTERVAL_SECONDS=60
OC101_WD_TIMESTAMP_SKEW_SECONDS=120
OC101_WD_NONCE_TTL_SECONDS=600

# Auto-restart policy
OC101_WD_AUTO_RESTART_ENABLED=true
OC101_WD_RESTART_COOLDOWN_SECONDS=1800
OC101_WD_MAX_AUTO_RESTART_FAILURES=3
OC101_WD_GATEWAY_RECHECK_DELAY_SECONDS=45

# Monitored target
OC101_WD_MONITORED_HOST=<target-host>
OC101_WD_MONITORED_SERVICE=openclaw-gateway
# If unset, watchdog uses scripts/oc101 next to itself.
# OC101_WD_OC101_PATH=/path/to/openclaw-oc101-ops/scripts/oc101

# MUST be an independent operations bot, not the monitored bot
OC101_WD_TELEGRAM_BOT_TOKEN=replace-with-ops-bot-token
OC101_WD_TELEGRAM_CHAT_ID=replace-with-chat-id

# Local files
OC101_WD_STATE_FILE=~/.codex/tmp/oc101-watchdog-state.json
OC101_WD_LOG_FILE=~/.codex/log/oc101-watchdog.log
