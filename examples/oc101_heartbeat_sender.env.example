# Heartbeat sender env
# Use `export` to make values visible to child processes.
export OC101_HB_WEBHOOK_URL=http://<watchdog-host>:18891/heartbeat
export OC101_HB_SHARED_SECRET=change-this-secret
export OC101_HB_HOST=<target-host>
export OC101_HB_SERVICE=openclaw-gateway
export OC101_HB_STATUS=ok
export OC101_HB_VERSION=unknown
export OC101_HB_CHANNEL=stable
